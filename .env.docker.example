# Docker deployment — copy this file to .env, then: docker compose up -d
# Service URLs are not needed; this service only calls the public SNCB endpoint.

# Docker Compose file to use (pick one and uncomment)
# COMPOSE_FILE=compose.port.yaml
# COMPOSE_FILE=compose.traefik.yaml
# COMPOSE_FILE=compose.cloudflared.yaml

# Port the service listens on
PORT=3000

# Cloudflare Tunnel token (cloudflared deployment only)
# TUNNEL_TOKEN=
