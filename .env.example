# Copy this file to .env.
#
# Local development (running outside Docker):
#   - set PORT (the frontend dev server runs on 5173)
#   - ignore the COMPOSE_FILE / TUNNEL_TOKEN entries below
#
# Docker deployment (docker compose up -d):
#   - uncomment one COMPOSE_FILE line to pick the deployment variant
#   - set TUNNEL_TOKEN when using the cloudflared variant
#
# This service only calls the public SNCB endpoint, so no service URLs are needed.

# Docker Compose file to use (pick one and uncomment — Docker deployment only)
# COMPOSE_FILE=compose.port.yaml
# COMPOSE_FILE=compose.traefik.yaml
# COMPOSE_FILE=compose.cloudflared.yaml

# Port the service listens on
PORT=3000

# Cloudflare Tunnel token (cloudflared deployment only)
# TUNNEL_TOKEN=
